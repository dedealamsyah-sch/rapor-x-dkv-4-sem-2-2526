* { margin:0; padding:0; box-sizing:border-box; }
body { font-family:'Plus Jakarta Sans',sans-serif; background:#F8FAFF; color:var(--slate-900); }

/* HEADER */
.header {
  background: linear-gradient(135deg,#1e3a8a,#3B4FE4,#7C3AED);
