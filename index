  const absenF = document.getElementById('filterAbsen').value;
  const deltaF = document.getElementById('filterDelta').value;

  filtered = data.filter(d => {
    if(q && !d.nama.toLowerCase().includes(q)) return false;
    if(tren && d.tren !== tren) return false;
    if(rankF === 'top5' && d.r2 > 5) return false;
    if(rankF === 'top10' && d.r2 > 10) return false;
    if(rankF === 'bot10') {
      const sorted = [...data].sort((a,b)=>b.r2-a.r2);
      const bot10names = sorted.slice(0,10).map(x=>x.nama);
      if(!bot10names.includes(d.nama)) return false;
    }
    if(absenF === '0' && d.totalAbsen !== 0) return false;
    if(absenF === 'low' && d.totalAbsen > 5) return false;
    if(absenF === 'high' && d.totalAbsen <= 10) return false;
    if(deltaF === 'high' && d.delta < 2.5) return false;
    if(deltaF === 'mid' && (d.delta < 1 || d.delta >= 2.5)) return false;
    if(deltaF === 'low' && d.delta >= 1) return false;
    return true;
  });

  sortFiltered();
  renderTable();
}

function sortFiltered() {
  filtered.sort((a,b) => {
    let va = a[sortKey], vb = b[sortKey];
    if(typeof va === 'string') va=va.toLowerCase(), vb=vb.toLowerCase();
    return va < vb ? -sortDir : va > vb ? sortDir : 0;
  });
}

function sortTable(key) {
  // update sort direction
  if(sortKey === key) sortDir *= -1;
  else { sortKey = key; sortDir = 1; }

  // update header icons
  document.querySelectorAll('th').forEach(th => {
    th.classList.remove('sort-asc','sort-desc');
  });
  event.currentTarget.classList.add(sortDir===1 ? 'sort-asc':'sort-desc');

  sortFiltered();
  renderTable();
}

function resetFilter() {
  document.getElementById('searchInput').value='';
  document.getElementById('filterTren').value='';
  document.getElementById('filterRankS2').value='';
  document.getElementById('filterAbsen').value='';
  document.getElementById('filterDelta').value='';
  filtered = [...data];
  sortKey='r2'; sortDir=1;
  document.querySelectorAll('th').forEach(th=>th.classList.remove('sort-asc','sort-desc'));
  sortFiltered();
  renderTable();
}

// init: sort by rank S2 asc
filtered.sort((a,b)=>a.r2-b.r2);
renderTable();
</script>
</body>
