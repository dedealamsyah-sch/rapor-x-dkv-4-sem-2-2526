}
.header h1 { font-size:22px; font-weight:800; }
.header p { font-size:13px; opacity:.75; margin-top:4px; }

/* TOOLBAR */
.toolbar {
  background:white; padding:16px 20px;
  border-bottom:1px solid var(--slate-300);
  display:flex; flex-wrap:wrap; gap:10px; align-items:center;
  position:sticky; top:0; z-index:100;
  box-shadow:0 2px 8px rgba(0,0,0,.06);
}
.search-box {
  position:relative; flex:1; min-width:200px;
}
.search-box input {
  width:100%; padding:8px 12px 8px 36px;
  border:1.5px solid var(--slate-300); border-radius:8px;
  font-size:13px; font-family:inherit; outline:none;
}
.search-box input:focus { border-color:var(--indigo); }
.search-box::before { content:'🔍'; position:absolute; left:10px; top:50%; transform:translateY(-50%); font-size:13px; }

select {
  padding:8px 12px; border:1.5px solid var(--slate-300); border-radius:8px;
  font-size:13px; font-family:inherit; outline:none; background:white; cursor:pointer;
}
select:focus { border-color:var(--indigo); }

.btn-reset {
  padding:8px 16px; background:var(--slate-100); border:1.5px solid var(--slate-300);
  border-radius:8px; font-size:13px; font-family:inherit; font-weight:600;
  cursor:pointer; color:var(--slate-700);
}
.btn-reset:hover { background:var(--slate-300); }

.result-count {
  font-size:12px; color:var(--slate-500); font-weight:600; white-space:nowrap;
}

/* TABLE WRAPPER */
.table-wrap { overflow-x:auto; padding:16px 20px; }
table { width:100%; border-collapse:collapse; font-size:13px; min-width:900px; }

/* HEADER ROW */
thead tr { background:var(--slate-900); color:white; }
th {
  padding:11px 12px; text-align:left; font-size:11px; font-weight:700;
  text-transform:uppercase; letter-spacing:.5px; white-space:nowrap;
  user-select:none; cursor:pointer; position:relative;
}
th:hover { background:#1e293b; }
th .sort-icon { margin-left:4px; opacity:.4; font-size:10px; }
th.sort-asc .sort-icon::after { content:'▲'; opacity:1; }
th.sort-desc .sort-icon::after { content:'▼'; opacity:1; }
th:not(.sort-asc):not(.sort-desc) .sort-icon::after { content:'⇅'; }

/* BODY ROWS */
tbody tr { border-bottom:1px solid #F1F5F9; transition:background .1s; }
tbody tr:hover { background:#EEF2FF; }
tbody tr:nth-child(even) { background:#FAFBFF; }
tbody tr:nth-child(even):hover { background:#EEF2FF; }
td { padding:9px 12px; vertical-align:middle; }

.nama-cell { font-weight:700; font-size:12.5px; }
.num-cell { font-family:'Space Grotesk',sans-serif; font-weight:600; text-align:right; }

/* RANK BADGE */
.rank-badge {
  display:inline-flex; align-items:center; justify-content:center;
  width:28px; height:28px; border-radius:7px;
  font-weight:800; font-size:12px; font-family:'Space Grotesk',sans-serif;
}
.r1 { background:#FEF3C7; color:#D97706; }
.r2 { background:#E0E7FF; color:#4338CA; }
.r3 { background:#DCFCE7; color:#15803D; }
.rn { background:#F1F5F9; color:#64748B; }

/* TREN BADGE */
.badge { padding:3px 9px; border-radius:6px; font-size:11px; font-weight:700; white-space:nowrap; }
.naik  { background:#DCFCE7; color:#15803D; }
.turun { background:#FEE2E2; color:#DC2626; }
.tetap { background:#F1F5F9; color:#64748B; }

/* DELTA */
.delta-pos { color:#10B981; font-weight:700; font-family:'Space Grotesk',sans-serif; }
.delta-neg { color:#F43F5E; font-weight:700; font-family:'Space Grotesk',sans-serif; }

/* NILAI BAR */
.nilai-bar-wrap { display:flex; align-items:center; gap:8px; }
.nilai-bar-bg { flex:1; height:6px; background:#E2E8F0; border-radius:99px; min-width:60px; }
.nilai-bar-fill { height:100%; border-radius:99px; background:linear-gradient(90deg,#3B4FE4,#7C3AED); }

/* ABSEN CHIP */
.absen-chip { display:inline-flex; gap:4px; }
.chip { padding:2px 6px; border-radius:4px; font-size:10px; font-weight:700; }
.chip-s { background:#FEF3C7; color:#92400E; }
.chip-i { background:#DBEAFE; color:#1E40AF; }
.chip-a { background:#FEE2E2; color:#991B1B; }

/* EMPTY STATE */
.empty { text-align:center; padding:48px; color:var(--slate-500); font-size:14px; }

/* FOOTER */
.footer-bar {
  background:white; padding:12px 20px; border-top:1px solid var(--slate-300);
  display:flex; flex-wrap:wrap; gap:12px; align-items:center;
  font-size:12px; color:var(--slate-500);
}
.stat-pill {
  background:var(--slate-100); padding:4px 10px; border-radius:6px;
  font-weight:700; color:var(--slate-700);
}

/* LEGEND */
.legend-row { display:flex; flex-wrap:wrap; gap:8px; padding:10px 20px; background:white; border-bottom:1px solid var(--slate-300); }
.legend-item { display:flex; align-items:center; gap:5px; font-size:11px; font-weight:600; color:var(--slate-500); }
.ldot { width:10px; height:10px; border-radius:2px; }
</style>
</head>
